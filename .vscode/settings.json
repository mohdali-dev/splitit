{
  "files.exclude": {
    "**/node_modules": true,
    "**/.git": true,
    "**/dist": true,
    "**/android": true,
    "**/.gradle": true
  },
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": false
  },
  "markdownlint.enable": false,
  "markdownlint.config": {
    "default": false
  }
}
